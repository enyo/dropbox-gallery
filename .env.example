# --- Dropbox (OAuth refresh-token flow) ---
# From the App Console -> Settings tab:
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
# Captured once via `node scripts/dropbox-auth.mjs` (never expires):
DROPBOX_REFRESH_TOKEN=
# OPTIONAL: a short-lived "Generate access token" value for instant local testing
# before the refresh token is captured. Code prefers the refresh token if present.
DROPBOX_ACCESS_TOKEN=

# --- App auth & signing ---
# Password to access /admin:
ADMIN_PASSWORD=
# Signs Gallery Link tokens (rotating this invalidates ALL links):
GALLERY_SIGNING_SECRET=
# Signs the admin session cookie:
SESSION_SECRET=
