{
	"name": "dropbox-gallery",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"test": "vitest run",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"auth": "node scripts/dropbox-auth.mjs",
		"dropbox:check": "node scripts/dropbox-check.mjs",
		"admin:create": "node scripts/create-admin.mjs",
		"db:create": "wrangler d1 create dropbox-gallery",
		"db:migrate:local": "wrangler d1 migrations apply dropbox-gallery --local",
		"db:migrate": "wrangler d1 migrations apply dropbox-gallery --remote",
		"deploy": "vite build && wrangler deploy"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260702.1",
		"@standard-schema/spec": "^1.1.0",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^26.0.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"wrangler": "^4.107.0"
	},
	"dependencies": {
		"photoswipe": "^5.4.4"
	}
}
